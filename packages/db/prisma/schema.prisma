// Publeca data model
// Oversell prevention lives here: atomic decrement (see src/inventory.ts),
// a CHECK constraint added via migration SQL, time-boxed Reservation holds,
// and idempotent payment handling via unique providerRef.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Accounts ───────────────────────────

enum Role {
  HOST
  ADMIN
}

model Host {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  role         Role            @default(HOST)
  kycStatus    String          @default("pending")
  events       Event[]
  paymentConfigs PaymentConfig[]
  // Team: memberships this host owns, and memberships granting this host access elsewhere.
  ownedMemberships TeamMember[] @relation("OwnedMemberships")
  memberships      TeamMember[] @relation("Memberships")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum TeamRole {
  MANAGER // full access to the owner's events (edit, publish, scan, attendees)
  STAFF // door staff: scan + view attendees only
}

// Grants another user (by email) access to an owner host's events.
model TeamMember {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Host     @relation("OwnedMemberships", fields: [ownerId], references: [id], onDelete: Cascade)
  memberEmail String
  memberId    String? // linked to a Host once that email signs up / exists
  member      Host?    @relation("Memberships", fields: [memberId], references: [id], onDelete: SetNull)
  role        TeamRole @default(STAFF)
  createdAt   DateTime @default(now())

  @@unique([ownerId, memberEmail])
  @@index([memberId])
}

// ─────────────────────────── Events ───────────────────────────

enum EventStatus {
  DRAFT
  LIVE
  ENDED
}

model Event {
  id          String       @id @default(cuid())
  hostId      String
  host        Host         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  slug        String       @unique
  title       String
  description String?
  venue       String?
  // Venue location (Google Places). All optional — venue text alone still works.
  venueLat    Float?
  venueLng    Float?
  placeId     String?
  mapsUrl     String?
  startsAt    DateTime
  endsAt      DateTime?
  currency    String       @default("LKR")
  status      EventStatus  @default(DRAFT)
  ticketTypes TicketType[]
  orders      Order[]
  seats       Seat[]
  landingPage LandingPage?
  // Optional visual seating layout: { blocks: [{ id, name, rows, seats, x, y, ticketTypeId }] }
  seatingMap  Json?
  // Payment providers offered for THIS event (subset of the host's configured methods).
  // Empty = offer all of the host's enabled methods.
  paymentProviders String[] @default([])
  // Set when the pre-event reminder email batch has been sent (cron idempotency).
  reminderSentAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([hostId])
}

model TicketType {
  id            String        @id @default(cuid())
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  price         Decimal       @db.Decimal(12, 2)
  // Inventory: quantitySold counts confirmed seats; active holds are tracked
  // in Reservation and summed at availability-check time.
  quantityTotal Int
  quantitySold  Int           @default(0)
  salesEnd      DateTime?
  reservations  Reservation[]
  tickets       Ticket[]
  seats         Seat[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([eventId])
}

// One assigned seat, generated from a seating-map block. Source of truth for
// assigned-seating inventory (general-admission types still use quantitySold).
enum SeatStatus {
  AVAILABLE
  HELD
  SOLD
}

model Seat {
  id            String      @id @default(cuid())
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  block         String
  row           Int
  num           Int
  ticketTypeId  String?
  ticketType    TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  status        SeatStatus  @default(AVAILABLE)
  holdExpiresAt DateTime?
  orderId       String? // set while held/sold for an order (no FK to keep it simple)
  ticketId      String? // the issued ticket, once sold
  createdAt     DateTime    @default(now())

  @@unique([eventId, block, row, num])
  @@index([eventId, status])
  @@index([orderId])
}

// Time-boxed hold created when a buyer enters checkout. Counts against
// availability until it either converts to an Order/Ticket or expires and
// is swept back into the pool by a cron job.
enum ReservationStatus {
  HELD
  CONVERTED
  EXPIRED
}

model Reservation {
  id           String            @id @default(cuid())
  ticketTypeId String
  ticketType   TicketType        @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  quantity     Int
  status       ReservationStatus @default(HELD)
  expiresAt    DateTime
  orderId      String?
  createdAt    DateTime          @default(now())

  @@index([ticketTypeId, status, expiresAt])
}

// ─────────────────────────── Orders & tickets ───────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id          String      @id @default(cuid())
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyerName   String
  buyerEmail  String
  amount      Decimal     @db.Decimal(12, 2)
  currency    String      @default("LKR")
  status      OrderStatus @default(PENDING)
  provider    String // "payhere" | "koko" | "mintpay" | ...
  // Gateway's own reference. Unique so a replayed webhook can't double-issue.
  providerRef String?     @unique
  tickets     Ticket[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([eventId])
  @@index([buyerEmail])
}

enum TicketStatus {
  VALID
  USED
  VOID
}

model Ticket {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTypeId  String
  ticketType    TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  attendeeName  String
  attendeeEmail String
  // For assigned-seating tickets, the human seat label e.g. "VIP · Row 2 · Seat 5".
  seatLabel     String?
  // Signed token embedded in the QR; verified server-side at scan time.
  qrToken       String       @unique
  status        TicketStatus @default(VALID)
  checkedInAt   DateTime?
  checkedInBy   String?
  scanLogs      ScanLog[]
  createdAt     DateTime     @default(now())

  @@index([orderId])
}

enum ScanResult {
  OK
  ALREADY_USED
  INVALID
}

model ScanLog {
  id        String     @id @default(cuid())
  ticketId  String?
  ticket    Ticket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  scannedBy String
  result    ScanResult
  at        DateTime   @default(now())

  @@index([ticketId])
}

// ─────────────────────────── Landing page & tracking ───────────────────────────

model LandingPage {
  id           String  @id @default(cuid())
  eventId      String  @unique
  event        Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  theme        Json? // colors, layout options
  heroImageUrl String?
  videoUrl     String?
  copyBlocks   Json? // ordered content blocks (headings, paragraphs, etc.)

  // Per-event conversion tracking — pasted by the host in admin, no code needed.
  metaPixelId          String?
  metaCapiToken        String? // stored encrypted
  googleAdsId          String?
  googleConversionLabel String?

  updatedAt DateTime @updatedAt
}

// ─────────────────────────── Payment config ───────────────────────────

// Per-host gateway / BNPL credentials. `credentials` is an encrypted JSON blob
// (encrypted with CREDENTIALS_ENCRYPTION_KEY) — never returned to the client.
model PaymentConfig {
  id          String   @id @default(cuid())
  hostId      String
  host        Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  provider    String // "payhere" | "koko" | "mintpay" | "webxpay" | ...
  credentials String // encrypted JSON
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([hostId, provider])
}
