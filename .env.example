# ─────────────────────────────────────────────────────────────
# Publeca environment variables. Copy to .env and fill in.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- Database (Neon / Supabase Postgres) ---
# Pooled connection string for the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection for Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-32-byte-random-string"
# Base URL of the app (http://localhost:3000 in dev)
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Encryption for stored gateway credentials (32-byte base64) ---
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY="replace-me-with-a-32-byte-random-string"

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Publeca <tickets@publeca.com>"

# --- Cloudflare R2 (S3-compatible media storage) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="publeca-media"
R2_PUBLIC_URL="https://cdn.publeca.com"

# --- PayHere (Sri Lanka) — platform defaults; hosts can override per-account ---
# Set sandbox=true while testing
PAYHERE_SANDBOX="true"
PAYHERE_MERCHANT_ID=""
PAYHERE_MERCHANT_SECRET=""
